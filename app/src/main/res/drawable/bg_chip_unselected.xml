<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo gris claro -->
    <solid android:color="#EEEEEE"/>

    <!-- Bordes redondeados tipo chip -->
    <corners android:radius="20dp"/>

    <!-- Borde suave -->
    <stroke
        android:width="1dp"
        android:color="#D6D6D6"/>

    <!-- Espaciado interno -->
    <padding
        android:left="12dp"
        android:top="6dp"
        android:right="12dp"
        android:bottom="6dp"/>
</shape>